{
	"comments": {
		"lineComment": "//"
	},
	"brackets": [
		["Если", "КонецЕсли"],
		["Для", "КонецЦикла"],
		["Пока", "КонецЦикла"],
		["Процедура", "КонецПроцедуры"],
		["Функция", "КонецФункции"],
		["Попытка", "КонецПопытки"]
	],
	"autoClosingPairs": [
		{ "open": "\"", "close": "\"" },
		{ "open": "(", "close": ")" },
		{ "open": "[", "close": "]" }
	],
	"folding": {
		"markers": {
			"start": "^\\s*(?i)(Процедура|Функция|Если|Для|Пока|Попытка)\\b",
			"end": "^\\s*(?i)(КонецПроцедуры|КонецФункции|КонецЕсли|КонецЦикла|Исключение|КонецПопытки)\\b"
		}
	}
}